# Gateway Configuration
PORT=3000
LOG_LEVEL=info

# Authentication - use one or both options:

# Option 1: Anonymous API tokens (comma-separated)
# Clients using these tokens won't have a client ID in logs
FIRECRAWL_GATEWAY_API_TOKENS=your-secret-token-1,your-secret-token-2

# Option 2: Per-client tokens with identification (JSON format)
# Clients using these tokens will have their client ID logged
# FIRECRAWL_GATEWAY_CLIENT_TOKENS={"crawlbrief":"token-for-crawlbrief","monitor-app":"token-for-monitor"}

# Firecrawl Configuration
# Point to your self-hosted Firecrawl instance
FIRECRAWL_URL=http://localhost:3002

# If gateway runs in Docker and Firecrawl runs on host:
# FIRECRAWL_URL=http://host.docker.internal:3002

# If both run in Docker on same network:
# FIRECRAWL_URL=http://api:3002
